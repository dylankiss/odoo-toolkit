{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Odoo: Docker [master]",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "redirectOutput": false,
            "internalConsoleOptions": "openOnSessionStart",
            "justMyCode": false
        },
        {
            "name": "Debug Odoo: Docker [19.1 to 19.3]",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5683
            },
            "redirectOutput": false,
            "internalConsoleOptions": "openOnSessionStart",
            "justMyCode": false
        },
        {
            "name": "Debug Odoo: Docker [19.0]",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5682
            },
            "redirectOutput": false,
            "internalConsoleOptions": "openOnSessionStart",
            "justMyCode": false
        },
        {
            "name": "Debug Odoo: Docker [18.1 to 18.4]",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5681
            },
            "redirectOutput": false,
            "internalConsoleOptions": "openOnSessionStart",
            "justMyCode": false
        },
        {
            "name": "Debug Odoo: Docker [18.0]",
